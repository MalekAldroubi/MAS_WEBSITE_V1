# MAS International Care — Namecheap/Apache production policy.
# Vite copies this file into dist/.htaccess during `npm run build`.
# Enable SSL and HTTPS Redirect in Namecheap SSL/cPanel; do not duplicate that
# redirect here because control-panel-managed redirects are less prone to loops.

Options -Indexes -MultiViews
DirectoryIndex index.html
ServerSignature Off
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # One canonical hostname. The destination is fixed to avoid Host-header abuse.
  RewriteCond %{HTTP_HOST} ^www\.mascaregroup\.com$ [NC]
  RewriteRule ^ https://mascaregroup.com%{REQUEST_URI} [R=301,L,NE]

  # Remove duplicate index-document URLs while preserving query strings.
  RewriteCond %{THE_REQUEST} \s/+index\.html(?:[?\s]) [NC]
  RewriteRule ^index\.html$ / [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+ar/index\.html(?:[?\s]) [NC]
  RewriteRule ^ar/index\.html$ /ar/ [R=301,L,NE]
</IfModule>

<IfModule mod_mime.c>
  AddType image/svg+xml .svg
  AddType image/webp .webp
  AddType image/x-icon .ico
  AddType application/manifest+json .webmanifest
  AddType font/woff2 .woff2
  AddType font/otf .otf
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml application/manifest+json
  AddOutputFilterByType DEFLATE image/svg+xml font/otf
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/plain "access plus 1 hour"
  ExpiresByType application/xml "access plus 1 hour"
  ExpiresByType text/xml "access plus 1 hour"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # HTML must revalidate; fingerprinted assets can be cached permanently.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(?:css|js|woff2?|otf|svg|webp|png|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Same-origin by default. Cloudflare Turnstile is the only third-party code.
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'sha256-4zhakTPzxEpYyKav4jUhsZYDqV6bFeX9RsM4w7uUpcw=' 'sha256-rRM35i0F8HG4z+w9yusiytQc92aSdxp8lcpW35Kcfc4=' https://challenges.cloudflare.com; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; worker-src 'self' blob:; manifest-src 'self'; media-src 'self'; upgrade-insecure-requests"
  Header always set Strict-Transport-Security "max-age=31536000"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "accelerometer=(), autoplay=(), camera=(), display-capture=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), publickey-credentials-get=(), usb=()"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  Header always set X-Permitted-Cross-Domain-Policies "none"
  Header always unset X-Powered-By
</IfModule>

# Block private data, source maps, logs, backups, and editor files if uploaded.
<FilesMatch "(?i)(^\.|^mas-contact-config\.php$|\.(?:bak|conf|env|ini|log|map|old|orig|save|sql|sqlite|swp|tmp|ya?ml)~?$)">
  Require all denied
</FilesMatch>

# The public API is POST-only; browsers receive no cached PHP source responses.
<Files "contact.php">
  <IfModule mod_headers.c>
    Header always set Cache-Control "no-store"
  </IfModule>
</Files>
